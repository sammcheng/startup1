# App
DEBUG=false
ENVIRONMENT=development
HEALTHCHECK_URL=https://api.hackmarket.io/health
APP_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$
TOOL_REQUEST_TIMEOUT_SECONDS=30
MAX_REQUEST_BODY_BYTES=52428800

# Rate limiting
GATEWAY_RATE_LIMIT_PER_MINUTE=100
DEMO_RATE_LIMIT_PER_HOUR=10

# Local storage (used when S3 is not configured)
LOCAL_STORAGE_PATH=/tmp/hackmarket-storage

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hackmarket
POSTGRES_DB=hackmarket
POSTGRES_USER=hackmarket
POSTGRES_PASSWORD=change-me
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=20

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clerk (Auth) — backend
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...   # Clerk Dashboard → Webhooks → Signing Secret
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# Clerk (Auth) — frontend (Next.js, must be set in apps/web/.env.local)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Frontend API URL (set in apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=hackmarket-uploads

# OpenAI (AI code analysis agent)
OPENAI_API_KEY=sk-...

# Render-backed tool hosting
RENDER_API_KEY=rnd_...
RENDER_OWNER_ID=tea_...
RENDER_TOOL_REGION=oregon
RENDER_TOOL_PLAN=free
RENDER_TOOL_AUTO_DEPLOY=false
RENDER_TOOL_HEALTHCHECK_PATH=/health
RENDER_TOOL_DEPLOY_TIMEOUT_SECONDS=900
RENDER_REGISTRY_CREDENTIAL_ID=
RENDER_REGISTRY_CREDENTIAL_NAME=hackmarket-ghcr
IMAGE_REGISTRY_NAMESPACE=your-github-org
GHCR_USERNAME=your-github-username
GHCR_TOKEN=ghp_...

# Deployment / TLS
LETSENCRYPT_EMAIL=ops@hackmarket.io
