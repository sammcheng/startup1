{
  "name": "@hackmarket/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/validate-env.mjs && next build --webpack",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "type-check": "next typegen && node scripts/clean-next-types.mjs && tsc --noEmit",
    "validate:env": "node scripts/validate-env.mjs",
    "test:env": "node --test scripts/validate-env.test.mjs",
    "test:security": "node --test scripts/security-headers.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.5",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^5.4.0",
    "lucide-react": "^0.460.0",
    "motion": "^12.38.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "js-yaml": "4.2.0",
    "postcss": "8.5.15"
  }
}
