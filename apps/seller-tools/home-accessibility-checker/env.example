# Express.js Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# AI Provider Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_TIMEOUT_MS=20000
PUBLIC_APP_URL=https://hackmarket.io

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ANALYSIS_TIMEOUT_MS=45000

# Remote Fetch Timeouts
LISTING_FETCH_TIMEOUT_MS=10000
MAX_LISTING_HTML_BYTES=2097152
REMOTE_IMAGE_FETCH_TIMEOUT_MS=10000
MAX_REMOTE_IMAGE_BYTES=12582912

# Image Processing
MAX_FILE_SIZE=10485760
MAX_FILES=5
MAX_INLINE_IMAGES=5
IMAGE_QUALITY=85
MAX_IMAGE_WIDTH=2048
MAX_IMAGE_HEIGHT=2048

# Temporary Storage
TEMP_DIR=./tmp
UPLOAD_DIR=./tmp/uploads

# Optional: Database (if you want to add persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/accessibility_checker
# REDIS_URL=redis://localhost:6379
