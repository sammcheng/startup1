{
  "name": "accessibility-checker-express",
  "version": "1.0.0",
  "description": "Express.js backend for home accessibility analysis",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run lint && npm test"
  },
  "keywords": [
    "accessibility",
    "home",
    "ai",
    "vision",
    "express",
    "accessibility-checker"
  ],
  "author": "Accessibility Checker Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "sharp": "^0.32.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  }
}
